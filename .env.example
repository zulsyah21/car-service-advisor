# ============================================================
# .env.example — Copy this file to .env and fill in your values
# DO NOT commit .env to Git. Only commit this .env.example file.
# ============================================================

# Server Port (leave as 3000 for local development)
PORT=3000

# MySQL Database Configuration
# For local development: use 'localhost'
# For cloud deployment: use your cloud DB host (e.g., from Railway/PlanetScale)
DB_HOST=localhost
DB_USER=your_database_username
DB_PASSWORD=your_database_password
DB_NAME=car_service_advisor

# Google Gemini AI API Key
# Get your key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret (for authentication — generate a long random string)
# You can generate one at: https://generate-secret.vercel.app/64
JWT_SECRET=your_super_secret_jwt_key_here
